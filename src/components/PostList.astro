---
import type { CollectionEntry } from "astro:content";
import { $path } from "astro-typesafe-routes/path";
import Link from "./Link.astro";
import FormattedPostDate from "../features/posts/components/FormattedPostDate.astro";

interface Props {
  posts: Array<CollectionEntry<"post">>;
}

const { posts } = Astro.props;
---

<ul
  class="grid grid-cols-[auto_1fr] gap-x-md divide-y divide-zinc-200 dark:divide-zinc-800"
>
  {
    posts.map((post) => (
      <li class="col-span-full grid grid-cols-subgrid items-center py-sm">
        <Link
          class="contents"
          href={$path({ to: "/posts/[...id]", params: { id: post.id } })}
        >
          <FormattedPostDate
            class="text-sm text-zinc-500 dark:text-zinc-400"
            time={post.data.publishedAt}
          />
          <span transition:name={`post:title:${post.id}`}>
            {post.data.title}
          </span>
        </Link>
      </li>
    ))
  }
</ul>
