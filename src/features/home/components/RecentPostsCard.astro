---
import type { CollectionEntry } from "astro:content";
import { $path } from "astro-typesafe-routes/path";

import Link from "../../../components/Link.astro";
import FormattedPostDate from "../../posts/components/FormattedPostDate.astro";
import ArrowRightIcon from "~icons/lucide/arrow-right";

interface Props {
  posts: Array<CollectionEntry<"post">>;
}

const { posts } = Astro.props;
---

<section aria-labelledby="recent-posts-heading" class="p-md md:p-lg">
  <div class="mb-md flex items-end justify-between gap-md">
    <h2
      id="recent-posts-heading"
      class="text-xl font-semibold text-zinc-950 dark:text-zinc-50"
    >
      Recent posts
    </h2>

    <Link
      class="inline-flex shrink-0 items-center gap-xs rounded-md focus:outline-2 focus:outline-offset-4 focus:outline-zinc-950 dark:focus:outline-zinc-50"
      href={$path({ to: "/posts" })}
    >
      View all <ArrowRightIcon aria-hidden="true" />
    </Link>
  </div>

  <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
    {
      posts.map((post) => (
        <li class="py-2xs first:pt-0 last:pb-0">
          <Link
            class="grid grid-cols-[auto_1fr] items-baseline gap-md rounded-xl py-sm focus:outline-2 focus:outline-offset-2 focus:outline-zinc-950 dark:focus:outline-zinc-50"
            href={$path({ to: "/posts/[...id]", params: { id: post.id } })}
          >
            <FormattedPostDate
              class="text-sm text-zinc-500 dark:text-zinc-400"
              time={post.data.publishedAt}
            />
            <span
              class="leading-relaxed font-medium text-zinc-900 dark:text-zinc-100"
              transition:name={`post:title:${post.id}`}
            >
              {post.data.title}
            </span>
          </Link>
        </li>
      ))
    }
  </ul>
</section>
