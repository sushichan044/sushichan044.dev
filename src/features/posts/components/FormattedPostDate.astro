---
import { HTMLAttributes } from "astro/types";

interface Props extends Omit<HTMLAttributes<"time">, "dateTime"> {
  time: Temporal.ZonedDateTime;
  /**
   * @default "short"
   */
  variant?: "short" | "long";
}

const { time, variant = "short", ...rest } = Astro.props;

const pretty =
  variant === "long"
    ? time.toLocaleString("ja-JP", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      })
    : time.toLocaleString("ja-JP", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      });
---

<time datetime={time.toString({ timeZoneName: "never" })} {...rest}>
  {pretty}
</time>
