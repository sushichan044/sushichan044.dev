---
import { SEO } from "astro-seo";
import { $path } from "astro-typesafe-routes/path";
import { ClientRouter } from "astro:transitions";
import { inlineApplyTheme } from "../lib/theme/index.browser";
import OpenGraph from "../components/meta/OpenGraph/OpenGraph.astro";
import "../app.css";

interface Props {
  title: string;

  /**
   * @default
   * sushichan044 の個人ウェブサイト。
   */
  description?: string;

  /**
   * @default
   * {
   *   url: new URL($path({to: "/opengraph.png"}), Astro.url)
   *   alt: "sushichan044.dev"
   * }
   */
  ogImage?: {
    url: URL;
    alt: string;
  };

  /**
   * @default false
   */
  disableTitleTemplate?: boolean;
}

const titleTemplate = Astro.props.disableTitleTemplate
  ? "%s"
  : "%s - sushichan044.dev";

const description =
  Astro.props.description ?? "sushichan044 の個人ウェブサイト。";

const defaultOGImageURL = new URL($path({ to: "/opengraph.png" }), Astro.url);
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={Astro.generator} name="generator" />

    <SEO
      title={Astro.props.title}
      description={description}
      titleTemplate={titleTemplate}
    />

    <OpenGraph
      basic={{ title: Astro.props.title }}
      optional={{
        description,
        locale: "ja_JP",
        siteName: "sushichan044.dev",
      }}
      image={Astro.props.ogImage ?? {
        url: defaultOGImageURL,
        alt: "sushichan044.dev",
      }}
      twitter={{
        card: "summary_large_image",
        creator: "@sushichan044",
        site: "@sushichan044",
      }}
    />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="author" href="http://www.hatena.ne.jp/sushichan044" />

    <ClientRouter />
    {
      /* Inline script to set data-theme before first paint to avoid flash of unstyled content. */
    }
    <script is:inline set:html={`(${inlineApplyTheme.toString()})()`} />

    {
      /* Insert custom head elements with
       * <Fragment slot="head">...heads</Fragment>
       */
    }
    <slot name="head" />
  </head>
  <slot />
</html>

<script>
  import {
    applyTheme,
    listenSystemThemeChange,
  } from "../lib/theme/index.browser";

  listenSystemThemeChange();

  // We must re-apply the theme after soft-navigation.
  // https://docs.astro.build/en/guides/view-transitions/#script-re-execution
  document.addEventListener("astro:after-swap", applyTheme);
</script>
